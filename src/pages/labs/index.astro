---
import { getCollection } from "astro:content";
import SectionIndexLayout from "../../layouts/SectionIndexLayout.astro";

const labs = (await getCollection("labs")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<SectionIndexLayout
	section="labs"
	title="Labs"
	description="Experiments, cluster drills, and test environments where the sharp edges usually show up first."
	items={labs.map((lab) => ({
		id: lab.id,
		...lab.data,
	}))}
/>
