---
import Layout from '../layouts/BlogPost.astro';

const careerStart = new Date('2024-03-01T00:00:00+07:00');
const today = new Date();

function formatDuration(from: Date, to: Date) {
	const totalMonths =
		(to.getFullYear() - from.getFullYear()) * 12 +
		(to.getMonth() - from.getMonth()) -
		(to.getDate() < from.getDate() ? 1 : 0);

	const safeMonths = Math.max(0, totalMonths);
	const years = Math.floor(safeMonths / 12);
	const months = safeMonths % 12;

	if (years === 0) return `${months} month${months === 1 ? '' : 's'}`;
	if (months === 0) return `${years} year${years === 1 ? '' : 's'}`;
	return `${years} year${years === 1 ? '' : 's'} ${months} month${months === 1 ? '' : 's'}`;
}

const devopsExperience = formatDuration(careerStart, today);
---

<Layout
	title="About Me"
	description="A short introduction to Tran Phan Vinh Sang and the purpose behind this personal DevOps blog."
	pubDate={new Date('2026-03-16')}
	heroImage="/blog-placeholder-about.jpg"
>
	<p>
		Welcome to my blog. My name is <strong>Tran Phan Vinh Sang</strong>, an ambitious DevOps engineer
		currently living and working in Vietnam.
	</p>

	<p>
		My current experience is in <strong>DevOps</strong>, with <strong>{devopsExperience}</strong> of
		hands-on work counted from March 2024 up to now. I graduated from
		<strong> Ho Chi Minh City University of Industry and Trade (HUIT)</strong>.
	</p>

	<p>
		On this blog, I share what I know, the personal projects I build, and the lessons I learn along
		the way. My goal is simple: to make useful knowledge available for free to anyone who may need it.
	</p>

	<p>
		I hope you have the best possible experience while exploring my blog. Thank you for stopping by.
	</p>
</Layout>
