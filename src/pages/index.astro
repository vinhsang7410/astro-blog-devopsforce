---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hello, DevOps Force!</h1>
			<p>
				This site is organized into practical sections so you can separate longer articles from quick
				notes and hands-on experiments.
			</p>
			<ul>
				<li><a href="/blog">Blog</a> for longer posts and tutorials</li>
				<li><a href="/labs">Labs</a> for experiments and test setups</li>
				<li><a href="/notes">Notes</a> for quick references and cheat sheets</li>
				<li><a href="/projects">Projects</a> for completed or in-progress builds</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
